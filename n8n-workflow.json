{
  "name": "Sandwitchy: Order Management",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "sandwitchy",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook — طلباتي",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        200,
        300
      ],
      "webhookId": "sandwitchy-orders"
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "ok",
        "options": {}
      },
      "id": "respond-ok",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        400,
        140
      ]
    },
    {
      "parameters": {
        "fieldToSplitOut": "body.messages",
        "options": {}
      },
      "id": "split-messages",
      "name": "Split — كل شخص",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [
        400,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-telegram",
              "leftValue": "={{ $json.telegram }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "check-telegram",
      "name": "عنده تليجرام؟",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        600,
        300
      ]
    },
    {
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{ '@' + $json.telegram }}",
        "text": "={{ \n'🍽️ *طلبك جاهز يا ' + $json.name + '!*\\n\\n' +\n'📋 *تفاصيل طلبك:*\\n' + $json.lines_text + '\\n\\n' +\n($json.delivery > 0 ? '🚗 *نصيبك من التوصيل:* ' + $json.delivery + ' ج\\n' : '') +\n'💰 *المبلغ الكلي عليك: ' + $json.total + ' ج*\\n\\n' +\n'_كود الجلسة: ' + $json.session_id + '_'\n}}",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "send-telegram",
      "name": "Send Telegram Message",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        850,
        200
      ],
      "credentials": {
        "telegramApi": {
          "id": "TELEGRAM_CREDENTIAL_ID",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "fields": {
          "values": [
            {
              "name": "status",
              "stringValue": "sent"
            }
          ]
        },
        "options": {}
      },
      "id": "log-success",
      "name": "Success",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1100,
        300
      ]
    },
    {
      "parameters": {
        "operation": "append",
        "sheetId": "ENTER_YOUR_SHEET_ID_HERE",
        "range": "A:Z",
        "columns": {
          "mappingMode": "manual",
          "value": {
            "Session ID": "={{ $json.session_id }}",
            "Date": "={{ new Date().toLocaleDateString() }}",
            "Name": "={{ $json.name }}",
            "Items": "={{ $json.lines_text }}",
            "Subtotal": "={{ $json.items_total }}",
            "Delivery": "={{ $json.delivery }}",
            "Total": "={{ $json.total }}",
            "Telegram": "={{ $json.telegram }}"
          },
          "matchingColumns": [],
          "schema": [
            { "id": "Session ID", "displayName": "Session ID", "required": false, "defaultReadOnly": false, "canBeUsedToMatch": false },
            { "id": "Date", "displayName": "Date", "required": false, "defaultReadOnly": false, "canBeUsedToMatch": false },
            { "id": "Name", "displayName": "Name", "required": false, "defaultReadOnly": false, "canBeUsedToMatch": false },
            { "id": "Items", "displayName": "Items", "required": false, "defaultReadOnly": false, "canBeUsedToMatch": false },
            { "id": "Subtotal", "displayName": "Subtotal", "required": false, "defaultReadOnly": false, "canBeUsedToMatch": false },
            { "id": "Delivery", "displayName": "Delivery", "required": false, "defaultReadOnly": false, "canBeUsedToMatch": false },
            { "id": "Total", "displayName": "Total", "required": false, "defaultReadOnly": false, "canBeUsedToMatch": false },
            { "id": "Telegram", "displayName": "Telegram", "required": false, "defaultReadOnly": false, "canBeUsedToMatch": false }
          ]
        }
      },
      "id": "google-sheets",
      "name": "Google Sheets — Log",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        1300,
        300
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets Account"
        }
      },
      "disabled": true
    }
  ],
  "connections": {
    "Webhook — طلباتي": {
      "main": [
        [
          {
            "node": "Respond OK",
